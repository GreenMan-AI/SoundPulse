{
  "expo": {
    "name": "SoundPulse",
    "slug": "SoundPulse",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/ic_launcher.png",
    "scheme": "soundpulse",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/ic_launcher.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agnis.soundpulse"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ic_launcher.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.greenmanai.soundpulse",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SoundPulse pieprasa piekļuvi fotogrāfijām profila bildes izvēlei.",
          "cameraPermission": "SoundPulse pieprasa piekļuvi kamerai profila bildes uzņemšanai."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0f",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "315aaae6-375a-46b8-a520-bdb7acc3fae8"
      }
    },
    "owner": "greenman"
  }
}
